# Anti-Fraud Service Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini  # or gpt-4, gpt-3.5-turbo

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/kebbi
REDIS_URL=redis://localhost:6379

# Service Configuration
SERVICE_PORT=8000
SERVICE_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
DEBUG_MODE=false

# GPT Configuration (Optional - will use defaults if not set)
GPT_MAX_TOKENS=300
GPT_TEMPERATURE=0.8
GPT_TOP_P=0.95